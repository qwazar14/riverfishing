{
  "schemaVersion": 1,
  "id": "riverfishing",
  "version": "${version}",
  "name": "River Fishing",
  "description": "A deep, realistic river & ice-fishing simulator built as a modpack anchor.",
  "authors": [
    "Qwazar"
  ],
  "contact": {
    "homepage": "https://github.com/qwazar14/riverfishing",
    "sources": "https://github.com/qwazar14/riverfishing"
  },
  "license": "MIT",
  "icon": "assets/riverfishing/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.riverfishing.fabric.RiverFishingFabric"
    ],
    "client": [
      "com.riverfishing.fabric.RiverFishingFabricClient"
    ]
  },
  "mixins": [
    "riverfishing.mixins.json",
    "riverfishing-fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": ">=26.1",
    "java": ">=25",
    "architectury": ">=20.0.0",
